# ===========================================
# 토모토모 (Tomotomo) 환경 변수
# 사용법: 이 파일을 복사해 .env 로 저장한 뒤 값을 채우세요.
# .env 는 .gitignore 에 포함되어 있어 저장소에 올라가지 않습니다.
# ===========================================

# Google Gemini API (필수 — AI 채팅·DM 분석)
# https://aistudio.google.com/apikey 등에서 API 키 발급
GEMINI_API_KEY=your_gemini_api_key_here
# 모델명 (앱 기본값: gemini-2.5-flash-lite — 텍스트 기준 가장 저렴한 Standard 요금대)
# 균형·품질: gemini-2.5-flash / 고품질: gemini-2.5-pro / Gemini 3: gemini-3.1-flash-lite-preview 등
# 2.0 계열은 deprecated 예정 — https://ai.google.dev/gemini-api/docs/deprecations
GEMINI_MODEL=gemini-2.5-flash-lite
# 선택: temperature (>0), maxOutputTokens (기본 512 — 느리면 유지, JSON 잘리면 768~1024)
# GEMINI_TEMPERATURE=0.2
# GEMINI_MAX_OUTPUT_TOKENS=512
# 한 요청에 넣는 대화 턴 수( user+model 쌍 ×2 = Content 개수, 기본 24). 길면 줄이면 더 빨라질 수 있음.
# GEMINI_MAX_CHAT_CONTENTS=16

# Supabase (필수 - 회원/캐릭터/채팅 등)
# 대시보드: Settings > API > Publishable and secret API keys
SUPABASE_URL=https://your-project.supabase.co
# Publishable key (클라이언트용, 브라우저/앱에 노출 가능, RLS 적용)
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
# Secret key는 서버/Edge Functions 전용 — .env에 넣지 말 것
