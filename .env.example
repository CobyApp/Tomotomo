# ===========================================
# 토모토모 (Tomotomo) 환경 변수
# 사용법: 이 파일을 복사해 .env 로 저장한 뒤 값을 채우세요.
# .env 는 .gitignore 에 포함되어 있어 저장소에 올라가지 않습니다.
# ===========================================

# Ollama 호환 AI API (필수 — AI 채팅·DM 분석)
# 예: 로컬 Ollama 또는 원격 서버 (끝의 / 는 생략 가능)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b
# 선택: 생성 옵션 (미설정 시 앱 기본값 — 속도 우선: 2048 / 512 / 0.15)
# num_ctx↓ = 프롬프트+히스토리 허용량 감소(더 빠름). num_predict↓ = 짧은 답(더 빠름).
# 어휘 JSON이 끊기면 OLLAMA_NUM_PREDICT=768~1024, 맥락 부족하면 OLLAMA_NUM_CTX=4096 정도로 올리세요.
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=512
OLLAMA_TEMPERATURE=0.15

# Supabase (필수 - 회원/캐릭터/채팅 등)
# 대시보드: Settings > API > Publishable and secret API keys
SUPABASE_URL=https://your-project.supabase.co
# Publishable key (클라이언트용, 브라우저/앱에 노출 가능, RLS 적용)
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
# Secret key는 서버/Edge Functions 전용 — .env에 넣지 말 것
